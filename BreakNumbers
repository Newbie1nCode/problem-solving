#include<iostream>
using namespace std;
int main(){
    long long n;
    cin>>n;

    long long max = 0; long long q;
    for (long long i = 0; i < n; ++i){
        long long count = 0;
        cin>>q;
        while(q != 0){
            if (q % 2 != 0){
                break;
            }
            q/=2;
            count++;
        }
        if (max < count){
            max = count;
        }
    }

    cout<<max;
}
